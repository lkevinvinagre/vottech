<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_alignParentStart="true">

    <ImageView
        android:id="@+id/project_img"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingStart="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

    <TextView
        android:id="@+id/projectTitle_lb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:layout_marginTop="16dp"
        android:text="Project Title"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/project_img"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/projectDescription_lb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:layout_marginTop="12dp"
        android:maxLines="3"
        android:text="Project description"
        app:layout_constraintStart_toEndOf="@+id/project_img"
        app:layout_constraintTop_toBottomOf="@+id/projectTitle_lb" />

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:layout_marginTop="20dp"
        android:text="vote"
        android:textColorLink="@color/blueblack"
        app:layout_constraintStart_toEndOf="@+id/project_img"
        app:layout_constraintTop_toBottomOf="@+id/projectDescription_lb"
        app:rippleColor="@color/blueblack" />
</androidx.constraintlayout.widget.ConstraintLayout>